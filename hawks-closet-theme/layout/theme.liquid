<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ page_title }} — Hawks Closet</title>
  {{ content_for_header }}
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500&display=swap" rel="stylesheet">
  {{ 'style.css' | asset_url | stylesheet_tag }}
</head>
<body>

<!-- ══════ DRAWER BACKDROP ══════ -->
<div class="drawer-backdrop" id="drawerBackdrop" onclick="closeDrawer()"></div>

<!-- ══════ DRAWER MENU ══════ -->
<div class="drawer" id="drawer">
  <div class="drawer-head">
    <span class="drawer-head-label">Menu</span>
    <button class="drawer-x" onclick="closeDrawer()" aria-label="Close">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 1l12 12M13 1L1 13" stroke="#000" stroke-width="1.4"/></svg>
    </button>
  </div>
  <nav class="drawer-nav">
    <a href="#" onclick="closeDrawer();scrollToShop();return false;">New Arrivals</a>
    <a href="#" onclick="closeDrawer();scrollToShop();return false;">Archive</a>
    <div class="drawer-sep"></div>
    <a href="#" onclick="closeDrawer();openAbout();return false;">About</a>
    <a href="mailto:hawkscloset@gmail.com">Contact</a>
  </nav>
  <div class="drawer-foot">&copy; {{ 'now' | date: '%Y' }} Hawks Closet</div>
</div>

<!-- ══════ NAV ══════ -->
<header class="nav">
  <button class="nav-ham" onclick="openDrawer()" aria-label="Menu">
    <span></span>
    <span></span>
  </button>
  <a class="nav-brand" href="/" onclick="scrollToShop();return false;">
    <img class="nav-logo" src="{{ 'logo.png' | asset_url }}" alt="Hawks Closet">
    <span class="nav-brand-name">Hawks Closet</span>
  </a>
  <div class="nav-right">
    <a href="/" onclick="scrollToShop();return false;">Shop</a>
    <div class="nav-cart" onclick="openCart()" role="button" aria-label="Cart">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
        <line x1="3" y1="6" x2="21" y2="6"/>
        <path d="M16 10a4 4 0 01-8 0"/>
      </svg>
      <div class="nav-cart-badge" id="cartBadge">0</div>
    </div>
  </div>
</header>

<!-- ══════ PAGE CONTENT ══════ -->
{{ content_for_layout }}

<!-- ══════ CART PANEL ══════ -->
<div class="cart-backdrop" id="cartBackdrop" onclick="closeCart()"></div>
<div class="cart-panel" id="cartPanel">
  <div class="cart-head">
    <span class="cart-head-label">Cart</span>
    <button class="cart-x" onclick="closeCart()">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 1l12 12M13 1L1 13" stroke="#000" stroke-width="1.4"/></svg>
    </button>
  </div>
  <div class="cart-body" id="cartBody">
    <div class="cart-empty-state" id="cartEmpty">
      <p>Your cart is empty</p>
      <small>Add pieces from the current drop<br>before they sell out.</small>
    </div>
  </div>
  <div class="cart-foot" id="cartFoot" style="display:none">
    <div class="cart-sub">
      <span class="cart-sub-label">Subtotal</span>
      <span class="cart-sub-val" id="cartTotal">$0</span>
    </div>
    <button class="btn-full btn-black" onclick="goCheckout()">Checkout &rarr;</button>
    <button class="btn-full btn-outline" onclick="closeCart()">Continue Shopping</button>
  </div>
</div>

<!-- ══════ PRODUCT DETAIL OVERLAY ══════ -->
<div class="overlay" id="overlayProduct">
  <div class="overlay-bar">
    <button class="overlay-bar-back" onclick="closeOverlay('overlayProduct')">
      <svg width="14" height="10" viewBox="0 0 14 10" fill="none"><path d="M5 1L1 5l4 4M1 5h12" stroke="#888" stroke-width="1.3" stroke-linecap="round"/></svg>
      Back
    </button>
    <span class="overlay-bar-title">Hawks Closet</span>
    <div class="overlay-bar-right">
      <div class="nav-cart" onclick="closeOverlay('overlayProduct');openCart();" style="justify-content:flex-end;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        <div class="nav-cart-badge" id="pdBadge">0</div>
      </div>
    </div>
  </div>
  <div class="pd-layout">
    <div class="pd-gallery" id="pdGallery">
      <div class="ph" style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;">
        <svg width="40" height="40" viewBox="0 0 36 36" fill="none"><rect x="4" y="8" width="28" height="22" rx="2" stroke="#ccc" stroke-width="1.5"/><path d="M4 14h28" stroke="#ccc" stroke-width="1.5"/><circle cx="18" cy="23" r="4" stroke="#ccc" stroke-width="1.5"/></svg>
      </div>
    </div>
    <div class="pd-info">
      <p class="pd-eyebrow">Hawks Closet</p>
      <h1 class="pd-name" id="pdName"></h1>
      <p class="pd-price" id="pdPrice"></p>
      <div class="pd-divider"></div>
      <div class="pd-specs" id="pdSpecs"></div>
      <div class="pd-desc" id="pdDesc"></div>
      <div class="pd-cta">
        <button class="pd-add primary" id="pdAddBtn" onclick="pdAddToCart()">Add to Cart</button>
        <button class="pd-add secondary" id="pdBuyBtn" onclick="pdBuyNow()">Buy Now</button>
        <p class="pd-note">One of one &mdash; first come, first served</p>
        <p class="pd-ig">Questions? <a href="https://instagram.com/hawks.vtg" target="_blank">DM @hawks.vtg &rarr;</a></p>
      </div>
    </div>
  </div>
</div>

<!-- ══════ ABOUT OVERLAY ══════ -->
<div class="overlay" id="overlayAbout">
  <div class="overlay-bar">
    <button class="overlay-bar-back" onclick="closeOverlay('overlayAbout')">
      <svg width="14" height="10" viewBox="0 0 14 10" fill="none"><path d="M5 1L1 5l4 4M1 5h12" stroke="#888" stroke-width="1.3" stroke-linecap="round"/></svg>
      Back
    </button>
    <span class="overlay-bar-title">About</span>
    <div class="overlay-bar-right"></div>
  </div>
  <div class="about-layout">
    <div class="about-photo">
      <img src="{{ 'about.jpg' | asset_url }}" alt="Hawks Closet">
    </div>
    <div class="about-info">
      <p class="about-eyebrow">Hawks Closet &mdash; Est. 2024</p>
      <h2 class="about-headline">The Person<br>Behind It</h2>
      <div class="about-rule"></div>
      <p class="about-bio">I'm Maxwell. Grew up in New Jersey with an eye for things other people walked past. Started Hawks Closet because I believed every piece has a story &mdash; and a price. I source obsessively: thrift runs, estate sales, yard sales at 6am, trunks full of stuff most people don't know what to do with. Everything that ends up here has been through my hands and earned its place. No filler. No bulk. Just pieces that matter, sold by someone who understands why they do. The fit has to be right. The price has to be right. Everything has a price.</p>
      <a href="https://instagram.com/hawks.vtg" class="about-ig" target="_blank">@hawks.vtg</a>
    </div>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<script src="{{ 'script.js' | asset_url }}"></script>
</body>
</html>
