{% layout none %}
<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Hawks Closet — Coming Soon</title>
  {{ content_for_header }}
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: #111;
      font-family: 'IBM Plex Mono', monospace;
      color: #fff;
      min-height: 100vh;
    }

    /* ── Screen wrapper ── */
    .screen {
      position: relative;
      width: 100%;
      min-height: 100vh;
      overflow: hidden;
    }

    /* ── Background ── */
    .bg {
      position: absolute;
      inset: 0;
      background-image: url('{{ 'Background.png' | asset_url }}');
      background-size: cover;
      background-position: center;
      opacity: 0.5;
    }
    .bg-overlay {
      position: absolute;
      inset: 0;
      background: rgba(0, 0, 0, 0.45);
    }

    /* ── Password — top left ── */
    .screen > form { display: contents; }
    .pw-corner {
      position: absolute;
      top: 2rem;
      left: 2rem;
      z-index: 10;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      width: 200px;
    }
    .pw-corner-label {
      font-size: 0.55rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.25);
    }
    .pw-error {
      font-size: 0.62rem;
      color: #e55;
    }
    .pw-input {
      background: transparent;
      border: 1px solid rgba(255, 255, 255, 0.12);
      color: rgba(255, 255, 255, 0.5);
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.75rem;
      padding: 0.65rem 1rem;
      width: 100%;
      outline: none;
      transition: border-color 0.15s;
      -webkit-appearance: none;
    }
    .pw-input::placeholder { color: rgba(255, 255, 255, 0.2); }
    .pw-input:focus { border-color: rgba(255, 255, 255, 0.3); }
    .pw-btn-ghost {
      background: transparent;
      color: rgba(255, 255, 255, 0.4);
      border: 1px solid rgba(255, 255, 255, 0.14);
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.72rem;
      letter-spacing: 0.08em;
      padding: 0.65rem 1rem;
      width: 100%;
      cursor: pointer;
      transition: border-color 0.15s, color 0.15s;
    }
    .pw-btn-ghost:hover { border-color: rgba(255,255,255,0.3); color: rgba(255,255,255,0.7); }

    /* ── Logo — top center ── */
    .logo-wrap {
      position: absolute;
      top: 2rem;
      left: 50%;
      transform: translateX(-50%);
      z-index: 10;
    }
    .logo-img {
      height: 36px;
      width: auto;
      filter: invert(1);
      display: block;
    }

    /* ── Center block — timer + SMS as one unit ── */
    .center-block {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      z-index: 2;
      width: 100%;
      max-width: 480px;
      padding: 0 2rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 2.5rem;
    }

    /* ── Countdown ── */
    .countdown-section {
      text-align: center;
      width: 100%;
    }
    .countdown-eyebrow {
      font-size: 0.6rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.4);
      margin-bottom: 0.75rem;
    }
    .countdown-grid {
      display: flex;
      gap: 1.5rem;
      justify-content: center;
      margin-bottom: 0.5rem;
    }
    .countdown-unit {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.35rem;
    }
    .countdown-num {
      font-size: clamp(4.2rem, 12vw, 6.75rem);
      font-weight: 300;
      line-height: 1;
      letter-spacing: -0.02em;
      color: #fff;
      min-width: 2ch;
      text-align: center;
    }
    .countdown-label {
      font-size: 0.52rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.35);
    }
    .countdown-sep {
      font-size: clamp(3rem, 9vw, 5.25rem);
      font-weight: 300;
      color: rgba(255, 255, 255, 0.2);
      align-self: flex-start;
      padding-top: 0.25rem;
      line-height: 1;
    }
    .countdown-date {
      font-size: 0.62rem;
      letter-spacing: 0.18em;
      color: rgba(255, 255, 255, 0.3);
      text-transform: uppercase;
      margin-top: 0.5rem;
    }

    /* ── SMS Section ── */
    .sms-section {
      width: 100%;
      text-align: center;
    }
    .sms-headline {
      font-size: 0.72rem;
      font-weight: 400;
      letter-spacing: 0.06em;
      color: rgba(255, 255, 255, 0.8);
      margin-bottom: 0.4rem;
    }
    .sms-sub {
      font-size: 0.62rem;
      color: rgba(255, 255, 255, 0.35);
      margin-bottom: 1.25rem;
      line-height: 1.6;
    }
    .sms-form {
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
      width: 100%;
      max-width: 300px;
      margin: 0 auto;
    }
    .sms-input {
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.18);
      color: #fff;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.78rem;
      padding: 0.7rem 1rem;
      width: 100%;
      outline: none;
      transition: border-color 0.15s;
      -webkit-appearance: none;
    }
    .sms-input::placeholder { color: rgba(255, 255, 255, 0.25); }
    .sms-input:focus { border-color: rgba(255, 255, 255, 0.4); }
    .sms-consent {
      display: flex;
      align-items: flex-start;
      gap: 0.5rem;
      text-align: left;
      cursor: pointer;
    }
    .sms-consent input[type="checkbox"] {
      width: 13px;
      height: 13px;
      min-width: 13px;
      margin-top: 2px;
      accent-color: #fff;
      cursor: pointer;
    }
    .sms-consent-text {
      font-size: 0.58rem;
      color: rgba(255, 255, 255, 0.3);
      line-height: 1.5;
    }
    .sms-btn {
      background: #fff;
      color: #000;
      border: none;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.75rem;
      letter-spacing: 0.1em;
      padding: 0.75rem 1rem;
      cursor: pointer;
      width: 100%;
      transition: background 0.15s;
    }
    .sms-btn:hover { background: #e0e0e0; }
    .sms-btn:disabled { opacity: 0.5; cursor: default; }
    .sms-msg {
      font-size: 0.68rem;
      line-height: 1.5;
      display: none;
    }
    .sms-msg.success { color: #7dda8a; }
    .sms-msg.error   { color: #e55; }

    /* ── Instagram — bottom center ── */
    .ig-line {
      position: absolute;
      bottom: 2rem;
      left: 50%;
      transform: translateX(-50%);
      z-index: 10;
      font-size: 0.62rem;
      color: rgba(255, 255, 255, 0.22);
      white-space: nowrap;
    }
    .ig-line a {
      color: rgba(255, 255, 255, 0.35);
      text-decoration: none;
      transition: color 0.15s;
    }
    .ig-line a:hover { color: rgba(255, 255, 255, 0.7); }

    /* ── Mobile adjustments ── */
    @media (max-width: 600px) {
      .pw-corner { width: 160px; }
      .center-block { padding: 0 1.25rem; }
      .countdown-grid { gap: 0.75rem; }
      .logo-wrap { display: none; }
      .countdown-num { font-size: 2.8rem; }
      .countdown-sep { font-size: 2rem; }
    }
  </style>
</head>
<body>

<div class="screen">
  <div class="bg"></div>
  <div class="bg-overlay"></div>

  <!-- Password — top left -->
  {% form 'storefront_password' %}
    <div class="pw-corner">
      <span class="pw-corner-label">Early access</span>
      {% if form.errors %}
        <p class="pw-error">Wrong password.</p>
      {% endif %}
      <input
        class="pw-input"
        type="password"
        name="password"
        placeholder="Password"
        autocomplete="current-password">
      <button class="pw-btn-ghost" type="submit">Enter &rarr;</button>
    </div>
  {% endform %}

  <!-- Logo — top center -->
  <div class="logo-wrap">
    <img class="logo-img" src="{{ 'logo.png' | asset_url }}" alt="Hawks Closet">
  </div>

  <!-- Timer + SMS — centered as one unit -->
  <div class="center-block">

    <div class="countdown-section">
      <p class="countdown-eyebrow">Drop goes live in</p>
      <div class="countdown-grid">
        <div class="countdown-unit">
          <span class="countdown-num" id="cd-days">--</span>
          <span class="countdown-label">Days</span>
        </div>
        <span class="countdown-sep">:</span>
        <div class="countdown-unit">
          <span class="countdown-num" id="cd-hours">--</span>
          <span class="countdown-label">Hrs</span>
        </div>
        <span class="countdown-sep">:</span>
        <div class="countdown-unit">
          <span class="countdown-num" id="cd-mins">--</span>
          <span class="countdown-label">Min</span>
        </div>
        <span class="countdown-sep">:</span>
        <div class="countdown-unit">
          <span class="countdown-num" id="cd-secs">--</span>
          <span class="countdown-label">Sec</span>
        </div>
      </div>
      <p class="countdown-date">April 24, 2026 &mdash; 12:00 PM EST</p>
    </div>

    <div class="sms-section">
      <p class="sms-headline">Get notified when we drop.</p>
      <p class="sms-sub">Drop your number &mdash; we'll text you the minute it goes live.</p>
      <div class="sms-form" id="smsForm">
        <input
          class="sms-input"
          type="tel"
          id="smsPhone"
          placeholder="(201) 555-0100"
          autocomplete="tel"
          inputmode="tel">
        <label class="sms-consent">
          <input type="checkbox" id="smsConsent">
          <span class="sms-consent-text">I agree to receive recurring automated marketing text messages at this number. Msg &amp; data rates may apply. Reply STOP to unsubscribe.</span>
        </label>
        <button class="sms-btn" id="smsSubmit" type="button" onclick="smsSignup()">Notify me &rarr;</button>
        <p class="sms-msg" id="smsMsg"></p>
      </div>
    </div>

  </div>

  <!-- Instagram — bottom center -->
  <p class="ig-line">
    Follow the drop &mdash; <a href="https://instagram.com/{{ settings.instagram_handle | default: 'hawks.vtg' }}" target="_blank">@{{ settings.instagram_handle | default: 'hawks.vtg' }}</a>
  </p>
</div>

<script>
  // ── Countdown ──────────────────────────────────────────
  (function () {
    var target = new Date('2026-04-24T12:00:00-04:00').getTime();
    function tick() {
      var diff = target - Date.now();
      if (diff <= 0) {
        ['cd-days','cd-hours','cd-mins','cd-secs'].forEach(function(id) {
          document.getElementById(id).textContent = '00';
        });
        return;
      }
      var d = Math.floor(diff / 86400000);
      var h = Math.floor((diff % 86400000) / 3600000);
      var m = Math.floor((diff % 3600000) / 60000);
      var s = Math.floor((diff % 60000) / 1000);
      document.getElementById('cd-days').textContent  = String(d).padStart(2, '0');
      document.getElementById('cd-hours').textContent = String(h).padStart(2, '0');
      document.getElementById('cd-mins').textContent  = String(m).padStart(2, '0');
      document.getElementById('cd-secs').textContent  = String(s).padStart(2, '0');
    }
    tick();
    setInterval(tick, 1000);
  })();

  // ── SMS Signup ─────────────────────────────────────────
  var KV_KEY  = 'TALeYF';
  var KV_LIST = 'X9XfPw';

  function smsSignup() {
    var phone   = document.getElementById('smsPhone').value.trim();
    var consent = document.getElementById('smsConsent').checked;
    var btn     = document.getElementById('smsSubmit');
    var msg     = document.getElementById('smsMsg');

    if (!phone) { showMsg('Please enter your phone number.', 'error'); return; }
    if (!consent) { showMsg('Please agree to receive texts to continue.', 'error'); return; }

    var digits = phone.replace(/\D/g, '');
    if (digits.length === 10) digits = '1' + digits;
    var e164 = '+' + digits;

    btn.disabled = true;
    btn.textContent = 'Sending\u2026';

    fetch('https://a.klaviyo.com/client/subscriptions/?company_id=' + encodeURIComponent(KV_KEY), {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'revision': '2024-10-15' },
      body: JSON.stringify({
        data: {
          type: 'subscription',
          attributes: {
            custom_source: 'Lock Screen',
            profile: {
              data: {
                type: 'profile',
                attributes: {
                  phone_number: e164
                }
              }
            }
          },
          relationships: {
            list: {
              data: { type: 'list', id: KV_LIST }
            }
          }
        }
      })
    })
    .then(function (res) {
      if (res.ok || res.status === 202) {
        document.getElementById('smsForm').innerHTML =
          '<p class="sms-msg success" style="display:block">You\'re in. We\'ll text you before the drop.</p>';
      } else {
        return res.json().then(function (data) {
          throw new Error((data.errors && data.errors[0] && data.errors[0].detail) || 'Something went wrong.');
        });
      }
    })
    .catch(function (err) {
      btn.disabled = false;
      btn.textContent = 'Notify me \u2192';
      showMsg(err.message || 'Something went wrong. Try again.', 'error');
    });
  }

  function showMsg(text, type) {
    var el = document.getElementById('smsMsg');
    el.textContent = text;
    el.className = 'sms-msg ' + type;
    el.style.display = 'block';
  }
</script>

</body>
</html>
